    font-family: 'Space Mono', monospace;
    font-size: 0.6rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--teal);
    margin-bottom: 1.5rem;
    opacity: 0;
    animation: progFadeUp 0.7s ease 0.2s forwards;
  }
  .cover-title {
    font-family: 'Cinzel', serif;
    font-weight: 900;
    font-size: clamp(2.8rem, 6vw, 4.5rem);
    letter-spacing: 0.06em;
    line-height: 1.05;
    color: var(--gold-pale);
    margin-bottom: 1.5rem;
    white-space: normal;
    overflow: visible;
    opacity: 0;
    animation: progFadeUp 0.7s ease 0.4s forwards;
  }
  .cover-dot { display: inline; }
  .cover-sub {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(1rem, 2vw, 1.3rem);
    font-style: italic;
    color: var(--text-dim);
    max-width: 560px;
    line-height: 1.65;
    opacity: 0;
    animation: progFadeUp 0.7s ease 0.6s forwards;
  }

  /* ── SECTIONS ── */
  .section {
    max-width: 860px;
    margin: 0 auto;
    padding: 4rem 2.5rem;
