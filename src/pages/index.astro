---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Quest Labs — Enter the Portal">

<!-- ===== HERO ===== -->
<section id="hero">
  <div class="hero-glow"></div>
  <div class="hero-glow-2"></div>
  <div class="portal-ring"></div>
  <div class="portal-ring"></div>
  <div class="portal-ring"></div>

  <p class="hero-eyebrow">Quest Labs · Afroasian Futurist Methodology · Est. 2022</p>
  <h1 class="hero-title">The Future Is Not<br>Predicted. It Is <span class="hero-highlight">Played.</span></h1>
  <p class="hero-sub">A living laboratory for futures literacy, healing-centered design, and the art of navigating what hasn't happened yet.</p>

  <div class="scroll-hint">
    <div class="scroll-line"></div>
    <span>Scroll to Begin</span>
  </div>
</section>

<!-- ===== JOIN THE ECOSYSTEM ===== -->
<section id="ecosystem">
  <div class="ecosystem-nebula"></div>
  <div class="ecosystem-nebula-2"></div>

  <p class="section-eyebrow">You've Crossed the Threshold · Three Cycles</p>
  <h2 class="section-title">Join the Ecosystem</h2>
  <p class="section-sub">The portal is open. Now choose your cycle — from open exploration to deep immersion.</p>

  <div class="ecosystem-cards">

    <div class="eco-card">
      <div class="eco-ring"></div>
      <div class="eco-glyph">◯</div>
      <div class="eco-tag">Donations Based · Monthly · Open Door</div>
      <h3 class="eco-label">Sandbox Sessions</h3>
      <p class="eco-desc">Monthly, Open Door gatherings on Luma. Donations based.</p>
      <p class="eco-desc">Leave with an artifact from the future or a fresh perspective of the future in your pocket.</p>
      <a href="https://luma.com/questlabs" class="btn-primary" target="_blank" rel="noopener noreferrer">Find a Session →</a>
    </div>

    <div class="eco-card">
      <div class="eco-ring"></div>
      <div class="eco-glyph">✦</div>
      <div class="eco-tag">Open Knowledge · Collective</div>
      <h3 class="eco-label">Digital Garden</h3>
      <p class="eco-desc">Plant seeds in the Living Knowledgebase. Zettelkasten method. We all feed this. Every node connects.</p>
      <a href="#" class="btn-primary">Coming Soon</a>
    </div>

    <div class="eco-card eco-card--fllip">
      <div class="eco-ring"></div>
      <div class="eco-fllip-left">
        <div class="eco-glyph">◈</div>
        <div class="eco-tag">By Invitation</div>
        <h3 class="eco-label">FLIP Cohorts</h3>
        <div class="fllip-acronym eco-fllip-acronym">
          <div class="fllip-letter"><span class="fl-big">F</span><span class="fl-word">Futures</span></div>
          <div class="fllip-letter"><span class="fl-big">L</span><span class="fl-word">Literacies</span></div>
          <div class="fllip-letter"><span class="fl-big">I</span><span class="fl-word">Invitational</span></div>
          <div class="fllip-letter"><span class="fl-big">P</span><span class="fl-word">Playground</span></div>
        </div>
      </div>
      <div class="eco-fllip-right">
        <p class="eco-desc" style="max-width:none; text-align:left;">Twelve weeks of embodied, participatory, healing-centered personal and collective futures development methodology.</p>
        <div class="eco-stats">
          <div class="eco-stat"><span class="eco-num">12</span><span class="eco-stat-label">Weeks</span></div>
          <div class="eco-stat"><span class="eco-num">5</span><span class="eco-stat-label">Founding Questors</span></div>
          <div class="eco-stat"><span class="eco-num">7</span><span class="eco-stat-label">Literacies</span></div>
          <div class="eco-stat"><span class="eco-num">∞</span><span class="eco-stat-label">Possible Futures</span></div>
        </div>
        <a href="/program" class="btn-primary" style="align-self:flex-start;">Accept the Invitation →</a>
      </div>
    </div>

  </div>
</section>

<!-- ===== ABCDEFG LORE ===== -->
<section id="lore">
  <div class="lore-grid">
    <div class="lore-text">
      <p class="section-eyebrow">The Framework · ABCDEFG</p>
      <h2 class="section-title">Seven Literacies for a World in Transition</h2>
      <p>Our futures are not missing. Our relationship to our futures has been <strong>crafted and commandeered</strong>. Decades of deficit-model education trained whole generations to react to crises rather than author alternatives — to manage uncertainty rather than inhabit it with skill.</p>
      <p>Quest Labs builds the <strong>infrastructure for what comes next</strong>. Not in service of onto broken systems. Built from scratch, from the ground up, with community wisdom as the foundation.</p>
      <p>The <strong>ABCDEFG Futures Literacies Framework</strong> emerged from <strong>545 contributions by 170 educators</strong> across two healing-centered gatherings. It is not a curriculum. It is a living methodology: seven interlocking capacities that, together, form a complete ecology of futures intelligence.</p>
      <p>This is shadow work and emergence work. <em>Everything everywhere all at once.</em></p>
      <a href="/science" class="btn-secondary" style="display:inline-block; margin-top:16px;">Explore the Science</a>
    </div>

    <div class="lore-visual">
      <div class="abcdefg-radial" id="radialChart"></div>
    </div>
  </div>
</section>

<!-- FOOTER -->
<footer>
  <div class="footer-inner">
    <div>
      <div class="footer-logo">Quest Labs</div>
      <div class="footer-tagline">Healing-Centered Futures</div>
    </div>
    <ul class="footer-links">
      <li><a href="/program">FLIP</a></li>
      <li><a href="/science">ABCDEFG Framework</a></li>
      <li><a href="#">Mosaics in the Making</a></li>
      <li><a href="/science">Research</a></li>
      <li><a href="#">Contact</a></li>
    </ul>
  </div>
  <div class="footer-copy">© 2026 Quest Labs · Makēda · All futures reserved · Berlin & Beyond</div>
</footer>

<script is:inline>
// ===== ABCDEFG RADIAL =====
const radial = document.getElementById('radialChart');
const letters = [
  { l: 'A', w: 'Affective', color: '#e8621a', angle: -90 },
  { l: 'B', w: 'Behavioral', color: '#d4a017', angle: -38 },
  { l: 'C', w: 'Cognitive', color: '#0fb8a0', angle: 14 },
  { l: 'D', w: 'Dialectical', color: '#c4446c', angle: 66 },
  { l: 'E', w: 'Experiential', color: '#7c3aed', angle: 118 },
  { l: 'F', w: 'Fun/Creative', color: '#0fb8a0', angle: 170 },
  { l: 'G', w: 'Generative', color: '#d4a017', angle: 222 }
];
const radius = 118;
letters.forEach(item => {
  const rad = (item.angle * Math.PI) / 180;
  const x = 160 + radius * Math.cos(rad);
  const y = 160 + radius * Math.sin(rad);

  const line = document.createElement('div');
  line.className = 'radial-line';
  const dist = radius - 40;
  line.style.cssText = `width:${dist}px; transform-origin: left center; transform: rotate(${item.angle}deg); left: 160px; top: 160px; background: linear-gradient(90deg, rgba(${hexToRgb(item.color)},0.3) 0%, transparent 100%);`;
  radial.appendChild(line);

  const node = document.createElement('div');
  node.className = 'radial-node';
  node.style.cssText = `left: ${x}px; top: ${y}px; border-color: ${item.color}40; --node-transform: translate(-50%,-50%); transform: translate(-50%,-50%);`;
  node.innerHTML = `<span class="nl" style="color:${item.color}">${item.l}</span><span class="nw">${item.w}</span>`;
  node.title = item.w;
  radial.appendChild(node);
});

const center = document.createElement('div');
center.className = 'radial-center';
center.textContent = 'FLF';
radial.appendChild(center);

function hexToRgb(hex) {
  const r = parseInt(hex.slice(1,3),16), g = parseInt(hex.slice(3,5),16), b = parseInt(hex.slice(5,7),16);
  return `${r},${g},${b}`;
}

</script>

</Layout>
