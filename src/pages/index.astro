---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Quest Labs — Enter the Portal">

<!-- ===== HERO ===== -->
<section id="hero">
  <div class="hero-glow"></div>
  <div class="hero-glow-2"></div>
  <div class="portal-ring"></div>
  <div class="portal-ring"></div>
  <div class="portal-ring"></div>

  <p class="hero-eyebrow">Quest Labs · Afroasian Futurist Methodology · Est. 2022</p>
  <h1 class="hero-title">The Future Is Not<br>Predicted. It Is <span class="hero-highlight">Played.</span></h1>
  <p class="hero-sub">A living laboratory for futures literacy, healing-centered design, and the art of navigating what hasn't happened yet.</p>

  <nav class="routing-strip" aria-label="Find your path">
    <a href="/educators">Educator or school leader?</a>
    <a href="/program">Ready to go deep?</a>
    <a href="/about#work-with-us">Bringing this to your org or school?</a>
    <a href="/educators#sponsored">Funding futures work that matters?</a>
  </nav>

  <div class="scroll-hint">
    <div class="scroll-line"></div>
    <span>Scroll to Begin</span>
  </div>
</section>

<!-- ===== JOIN THE ECOSYSTEM ===== -->
<section id="ecosystem">
  <div class="ecosystem-nebula"></div>
  <div class="ecosystem-nebula-2"></div>

  <p class="section-eyebrow">You've Crossed the Threshold · Four Cycles</p>
  <h2 class="section-title">Join the Ecosystem</h2>
  <p class="section-sub">The portal is open. Now choose your cycle — from open exploration to deep immersion.</p>

  <div class="ecosystem-cards">

    <div class="eco-card">
      <div class="eco-ring"></div>
      <div class="eco-glyph">◯</div>
      <div class="eco-tag">Donations Based · Monthly · Open Door</div>
      <h3 class="eco-label">Sandbox Sessions</h3>
      <p class="eco-desc">Monthly, Open Door gatherings on Luma. Donations based.</p>
      <p class="eco-desc">Leave with an artifact from the future or a fresh perspective of the future in your pocket.</p>
      <a href="https://luma.com/questlabs" class="btn-primary" target="_blank" rel="noopener noreferrer">Find a Session →</a>
    </div>

    <div class="eco-card eco-card--menagerie">
      <div class="eco-ring"></div>
      <div class="eco-glyph eco-glyph--menagerie">◆</div>
      <div class="eco-tag">Coming · Black Friday 2026</div>
      <h3 class="eco-label">The Black Menagerie</h3>
      <p class="eco-desc">A futures literacy card game rooted in Afroasian methodology - part game, part oracle, part mirror. Five creatures. Seventy-eight cards. Two editions: Think Cards for Humanity and an educator activity deck.</p>
      <a href="/black-menagerie" class="cta-secondary">Get Early Access →</a>
      <p class="eco-bm-note">No spam. Just a heads up when the doors open.</p>
    </div>

    <div class="eco-card eco-card--fllip">
      <div class="eco-ring"></div>
      <div class="eco-fllip-left">
        <div class="eco-glyph">◈</div>
        <div class="eco-tag">By Invitation</div>
        <h3 class="eco-label">FLIP Cohorts</h3>
        <div class="fllip-acronym eco-fllip-acronym">
          <div class="fllip-letter"><span class="fl-big">F</span><span class="fl-word">Futures</span></div>
          <div class="fllip-letter"><span class="fl-big">L</span><span class="fl-word">Literacies</span></div>
          <div class="fllip-letter"><span class="fl-big">I</span><span class="fl-word">Invitational</span></div>
          <div class="fllip-letter"><span class="fl-big">P</span><span class="fl-word">Playground</span></div>
        </div>
      </div>
      <div class="eco-fllip-right">
        <p class="eco-desc" style="max-width:none; text-align:left;">Twelve weeks of embodied, participatory, healing-centered personal and collective futures development.</p>
        <div class="eco-stats">
          <div class="eco-stat"><span class="eco-num">12</span><span class="eco-stat-label">Weeks</span></div>
          <div class="eco-stat"><span class="eco-num">6</span><span class="eco-stat-label">Founding Questors</span></div>
          <div class="eco-stat"><span class="eco-num">7</span><span class="eco-stat-label">Literacies</span></div>
          <div class="eco-stat"><span class="eco-num">∞</span><span class="eco-stat-label">Possible Futures</span></div>
        </div>
        <a href="/program" class="btn-primary" style="align-self:flex-start;">Accept the Invitation →</a>
      </div>
    </div>

    <div class="eco-card eco-card--fllip eco-card--educators">
      <div class="eco-ring"></div>
      <div class="eco-fllip-left">
        <div class="eco-glyph">◎</div>
        <div class="eco-tag">Now Taking Sign-Ups · Back to School 2026</div>
        <h3 class="eco-label">Educators Cohort</h3>
        <div class="eco-stats" style="flex-direction:column; gap:12px; margin-top:4px;">
          <div class="eco-stat"><span class="eco-num">20</span><span class="eco-stat-label">Educators Max</span></div>
          <div class="eco-stat"><span class="eco-num">ABCDEFG</span><span class="eco-stat-label">Futures Literacies Framework</span></div>
          <div class="eco-stat"><span class="eco-num">Fall 2026</span><span class="eco-stat-label">Launch</span></div>
        </div>
      </div>
      <div class="eco-fllip-right">
        <p class="eco-desc" style="max-width:none; text-align:left;">A community of praxis for educators trying to fit hope and future transformation into systems built for the past. Classroom teachers, instructional coaches, curriculum designers, and school leaders - join us to practice futures literacy as a living discipline in a playful way.</p>
        <a href="/educators" class="cta-primary" style="align-self:flex-start;">Raise My Hand →</a>
        <p class="eco-edu-note">Spots are limited. Sign-up is an expression of interest, not a commitment.</p>
      </div>
    </div>

  </div>
</section>

<!-- ===== ABCDEFG FRAMEWORK ===== -->
<section id="lore">
  <div class="portal-abc-inner">
    <p class="section-eyebrow">The Framework · ABCDEFG</p>
    <h2 class="section-title">Seven Literacies for a World in Transition</h2>
    <p class="portal-abc-sub">Most futures literacy frameworks center cognitive sense-making. The ABCDEFG Framework works across a fuller set of dimensions. Embodied futures asks something different of people. That pause is the point.</p>
    <div class="abc-strip portal-abc-strip">
      <div class="abc-cell"><span class="abc-letter">A</span><span class="abc-word">Affective</span><span class="abc-desc">Emotional intelligence · feeling states · mood · emotional processing</span></div>
      <div class="abc-cell"><span class="abc-letter">B</span><span class="abc-word">Behavioral</span><span class="abc-desc">Actions · practices · habits · rituals · repeated behaviors</span></div>
      <div class="abc-cell"><span class="abc-letter">C</span><span class="abc-word">Cognitive</span><span class="abc-desc">Thinking · analysis · knowledge · understanding · mental processing</span></div>
      <div class="abc-cell"><span class="abc-letter">D</span><span class="abc-word">Dialectical</span><span class="abc-desc">Tensions · contradictions · both/and thinking · holding complexity</span></div>
      <div class="abc-cell"><span class="abc-letter">E</span><span class="abc-word">Experiential</span><span class="abc-desc">Direct engagement · learning through experience · participatory practice</span></div>
      <div class="abc-cell"><span class="abc-letter">F</span><span class="abc-word">Fun / Creative</span><span class="abc-desc">Play · imagination · joy · creativity · experimentation</span></div>
      <div class="abc-cell"><span class="abc-letter">G</span><span class="abc-word">Generative</span><span class="abc-desc">Creating · midwiving new possibilities · hospicing toward transformation</span></div>
    </div>
    <a href="/foundations" class="btn-secondary" style="display:inline-block; margin-top:1.5rem;">Explore the Foundations</a>
  </div>
</section>

<!-- ===== COHORT 02 BRIDGE ===== -->
<section id="cohort-bridge">
  <div class="cohort-bridge-inner">
    <p class="cohort-bridge-eyebrow">Cohort 02 · Now Forming</p>
    <h2 class="cohort-bridge-heading">Ready to go deeper?</h2>
    <p class="cohort-bridge-body">FLIP — the Futures Literacies Invitational Playground — is a 12-week embodied journey toward your 2032 self. The founding cohort is full and already in motion. Cohort 02 is now forming.</p>
    <div class="cohort-bridge-ctas">
      <a href="/program#waitlist" class="btn-primary">Join the Cohort 02 waitlist →</a>
      <a href="/program" class="btn-secondary">Explore the program →</a>
    </div>
  </div>
</section>

<div class="page-bridge" style="max-width:860px; margin-left:auto; margin-right:auto; padding-left:2.5rem; padding-right:2.5rem;">
  <p>Not sure where to start?</p>
  <a href="https://lu.ma/questlabs" class="bridge-link">Find a Sandbox Session — open door, no commitment →</a>
</div>

<!-- FOOTER -->
<footer>
  <div class="footer-inner">
    <div>
      <div class="footer-logo">Quest Labs</div>
      <div class="footer-tagline">Healing-Centered Futures</div>
    </div>
    <ul class="footer-links">
      <li><a href="/program">FLIP</a></li>
      <li><a href="/foundations">Foundations</a></li>
      <li><a href="https://mosaiclifecoaching.co" target="_blank" rel="noopener noreferrer">Mosaics in the Making</a></li>
      <li><a href="mailto:questlabs.world@proton.me">Contact</a></li>
    </ul>
  </div>
  <div class="footer-copy">© 2026 Quest Labs · Makēda · All futures reserved · Berlin & Beyond</div>
</footer>




</Layout>
