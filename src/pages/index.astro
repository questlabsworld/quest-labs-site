---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Quest Labs, Enter the Portal">

<!-- ===== HERO ===== -->
<section id="hero">
  <div class="hero-glow"></div>
  <div class="hero-glow-2"></div>
  <div class="portal-ring"></div>
  <div class="portal-ring"></div>
  <div class="portal-ring"></div>

  <p class="hero-eyebrow">Quest Labs · Healing-Centered Futures · Est. 2022</p>
  <h1 class="hero-title">The Future Is Not<br>Predicted. It Is <span class="hero-highlight">Played.</span></h1>
  <p class="hero-sub">A living laboratory for futures literacy, healing-centered design, and the art of navigating what hasn't happened yet.</p>

  <nav class="routing-strip" aria-label="Find your path">
    <a href="/educators">Educator or school leader?</a>
    <a href="/program">Ready to go deep?</a>
    <a href="/about#work-with-us">Bringing this to your org or school?</a>
    <a href="/educators#sponsored">Funding futures work that matters?</a>
  </nav>

  <div class="scroll-hint">
    <div class="scroll-line"></div>
    <span>Scroll to Begin</span>
  </div>
</section>

<!-- ===== JOIN THE ECOSYSTEM ===== -->
<section id="ecosystem">
  <div class="ecosystem-nebula"></div>
  <div class="ecosystem-nebula-2"></div>

  <p class="section-eyebrow">You've Crossed the Threshold · Four Cycles</p>
  <h2 class="section-title">Join the Ecosystem</h2>
  <p class="section-sub">The portal is open. Now choose your cycle, from open exploration to deep immersion.</p>

  <div class="ecosystem-cards">

    <div class="eco-card">
      <div class="eco-ring"></div>
      <div class="eco-glyph">◯</div>
      <div class="eco-tag">Donations Based · Monthly · Open Door</div>
      <h3 class="eco-label">Sandbox Sessions</h3>
      <p class="eco-desc">Monthly, Open Door gatherings on Luma. Donations based.</p>
      <p class="eco-desc">Leave with an artifact from the future or a fresh perspective of the future in your pocket.</p>
      <a href="https://lu.ma/questlabs" class="btn-primary" target="_blank" rel="noopener noreferrer">Find a Session →</a>
    </div>

    <div class="eco-card eco-card--menagerie">
      <div class="eco-ring"></div>
      <div class="eco-glyph eco-glyph--menagerie">◆</div>
      <div class="eco-tag">Coming · Black Friday 2026</div>
      <h3 class="eco-label">The Black Menagerie</h3>
      <p class="eco-desc">A futures literacy card game part game, part oracle, part mirror. Five creatures. Seventy-eight cards. Two editions: Think Cards for Humanity and an educator activity deck.</p>
      <a href="/black-menagerie" class="cta-secondary">Get Early Access →</a>
      <p class="eco-bm-note">No spam. Just a heads up when the doors open.</p>
    </div>

    <div class="eco-card eco-card--fllip">
      <div class="eco-ring"></div>
      <div class="eco-fllip-left">
        <div class="eco-glyph">◈</div>
        <div class="eco-tag">By Invitation</div>
        <h3 class="eco-label">FLIP Cohorts</h3>
        <div class="fllip-acronym eco-fllip-acronym">
          <div class="fllip-letter"><span class="fl-big" style="display:block">F</span><span class="fl-word">Futures</span></div>
          <div class="fllip-letter"><span class="fl-big" style="display:block">L</span><span class="fl-word">Literacies</span></div>
          <div class="fllip-letter"><span class="fl-big" style="display:block">I</span><span class="fl-word">Invitational</span></div>
          <div class="fllip-letter"><span class="fl-big" style="display:block">P</span><span class="fl-word">Playground</span></div>
        </div>
      </div>
      <div class="eco-fllip-right">
        <p class="eco-desc" style="max-width:none; text-align:left;">Meet your future self through twelve weeks of play, practice, and collective imagination, then build the map to get there.</p>
        <div class="eco-stats">
          <div class="eco-stat"><span class="eco-num">12</span><span class="eco-stat-label">Weeks</span></div>
          <div class="eco-stat"><span class="eco-num">6</span><span class="eco-stat-label">Founding Questors</span></div>
          <div class="eco-stat"><span class="eco-num">7</span><span class="eco-stat-label">Literacies</span></div>
          <div class="eco-stat"><span class="eco-num">∞</span><span class="eco-stat-label">Possible Futures</span></div>
        </div>
        <a href="/program" class="btn-primary" style="align-self:flex-start;">Accept the Invitation →</a>
      </div>
    </div>

    <div class="eco-card eco-card--fllip eco-card--educators">
      <div class="eco-ring"></div>
      <div class="eco-fllip-left">
        <div class="eco-glyph">◎</div>
        <div class="eco-tag">Now Taking Sign-Ups · Back to School 2026</div>
        <h3 class="eco-label">Educators Cohort</h3>
        <div class="eco-stats" style="flex-direction:column; gap:12px; margin-top:4px;">
          <div class="eco-stat"><span class="eco-num">20</span><span class="eco-stat-label">Educators Max</span></div>
          <div class="eco-stat"><span class="eco-num">ABCDEFG</span><span class="eco-stat-label">Futures Literacies Framework</span></div>
          <div class="eco-stat"><span class="eco-num">Fall 2026</span><span class="eco-stat-label">Launch</span></div>
        </div>
      </div>
      <div class="eco-fllip-right">
        <p class="eco-desc" style="max-width:none; text-align:left;">A community of praxis for educators trying to fit hope and future transformation into systems built for the past. Classroom teachers, instructional coaches, curriculum designers, and school leaders - join us to practice futures literacy as a living discipline in a playful way.</p>
        <a href="/educators" class="cta-primary" style="align-self:flex-start;">Raise My Hand →</a>
        <p class="eco-edu-note">Spots are limited. Sign-up is an expression of interest, not a commitment.</p>
      </div>
    </div>

  </div>
</section>

<!-- ===== ABCDEFG FRAMEWORK ===== -->
<section id="lore">
  <div class="portal-abc-inner">
    <p class="section-eyebrow">The Framework · ABCDEFG</p>
    <h2 class="section-title">Seven Literacies for a World in Transition</h2>
    <p class="portal-abc-sub">Most futures literacy frameworks center cognitive sense-making. The ABCDEFG Framework works across a fuller set of dimensions. Embodied futures asks something different of people. That pause is the point.</p>
    <div class="abc-strip portal-abc-strip">
      <div class="abc-cell"><span class="abc-letter">A</span><span class="abc-word">Affective</span><span class="abc-desc">Emotional intelligence · feeling states · mood · emotional processing</span></div>
      <div class="abc-cell"><span class="abc-letter">B</span><span class="abc-word">Behavioral</span><span class="abc-desc">Actions · practices · habits · rituals · repeated behaviors</span></div>
      <div class="abc-cell"><span class="abc-letter">C</span><span class="abc-word">Cognitive</span><span class="abc-desc">Thinking · analysis · knowledge · understanding · mental processing</span></div>
      <div class="abc-cell"><span class="abc-letter">D</span><span class="abc-word">Dialectical</span><span class="abc-desc">Tensions · contradictions · both/and thinking · holding complexity</span></div>
      <div class="abc-cell"><span class="abc-letter">E</span><span class="abc-word">Experiential</span><span class="abc-desc">Direct engagement · learning through experience · participatory practice</span></div>
      <div class="abc-cell"><span class="abc-letter">F</span><span class="abc-word">Fun / Creative</span><span class="abc-desc">Play · imagination · joy · creativity · experimentation</span></div>
      <div class="abc-cell"><span class="abc-letter">G</span><span class="abc-word">Generative</span><span class="abc-desc">Creating · midwiving new possibilities · hospicing toward transformation</span></div>
    </div>
    <a href="/foundations" class="btn-secondary" style="display:inline-block; margin-top:1.5rem;">Explore the Foundations</a>
  </div>
</section>

<!-- ===== COHORT 02 BRIDGE ===== -->
<section id="cohort-bridge">
  <div class="cohort-bridge-inner">
    <p class="cohort-bridge-eyebrow">Cohort 02 · Now Forming</p>
    <h2 class="cohort-bridge-heading">Ready to go deeper?</h2>
    <p class="cohort-bridge-body">FLIP, the Futures Literacies Invitational Playground, is a 12-week embodied journey toward your 2032 self. The founding cohort is full and already in motion. Cohort 02 is now forming.</p>
    <div class="cohort-bridge-ctas">
      <a href="/program#waitlist" class="btn-primary">Join the Cohort 02 waitlist →</a>
      <a href="/program" class="btn-secondary">Explore the program →</a>
    </div>
  </div>
</section>

<div class="page-bridge" style="max-width:860px; margin-left:auto; margin-right:auto; padding-left:2.5rem; padding-right:2.5rem;">
  <p>Not sure where to start?</p>
  <a href="https://lu.ma/questlabs" class="bridge-link">Find a Sandbox Session, open door, no commitment →</a>
</div>

<!-- FOOTER -->
<footer>
  <div class="footer-inner">
    <div>
      <div class="footer-logo">Quest Labs</div>
      <div class="footer-tagline">Healing-Centered Futures</div>
    </div>
    <ul class="footer-links">
      <li><a href="/program">FLIP</a></li>
      <li><a href="/educators">Educators</a></li>
      <li><a href="/foundations">Foundations</a></li>
      <li><a href="/black-menagerie">Black Menagerie</a></li>
      <li><a href="/about">About</a></li>
      <li><a href="/contact">Contact</a></li>
    </ul>
  </div>
  <div class="footer-copy">2026 Quest Labs · Makeda · All futures reserved · Berlin &amp; Beyond</div>
</footer>




</Layout>

<style>
  /* ── SHARED SECTION TYPOGRAPHY ── */
  .section-eyebrow {
    font-family: 'Space Mono', monospace;
    font-size: 0.6rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--teal);
    margin-bottom: 0.75rem;
  }
  .section-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 500;
    line-height: 1.15;
    color: var(--text);
    margin-bottom: 1rem;
  }
  .section-sub {
    font-size: 1rem;
    color: var(--text-dim);
    line-height: 1.8;
    max-width: 640px;
    margin: 0 auto 3rem;
    text-align: center;
  }

  /* ── HERO ── */
  #hero {
    position: relative;
    min-height: 92vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    padding: 6rem 2rem 4rem;
    overflow: hidden;
  }
  .hero-glow {
    position: absolute;
    top: 10%; left: 50%;
    transform: translateX(-50%);
    width: 600px; height: 600px;
    background: radial-gradient(ellipse, rgba(107,63,160,0.18) 0%, transparent 65%);
    pointer-events: none;
    z-index: 0;
  }
  .hero-glow-2 {
    position: absolute;
    bottom: 5%; right: 10%;
    width: 400px; height: 400px;
    background: radial-gradient(ellipse, rgba(139,116,171,0.1) 0%, transparent 65%);
    pointer-events: none;
    z-index: 0;
  }
  .portal-ring {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    border-radius: 50%;
    border: 0.5px solid rgba(139,116,171,0.08);
    pointer-events: none;
    z-index: 0;
  }
  .portal-ring:nth-child(3) { width: 400px; height: 400px; }
  .portal-ring:nth-child(4) { width: 600px; height: 600px; border-color: rgba(139,116,171,0.05); }
  .portal-ring:nth-child(5) { width: 800px; height: 800px; border-color: rgba(139,116,171,0.03); }

  #hero > * { position: relative; z-index: 1; }

  .hero-eyebrow {
    font-family: 'Space Mono', monospace;
    font-size: 0.58rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--teal);
    margin-bottom: 1.75rem;
    opacity: 0;
    animation: progFadeUp 0.8s ease 0.2s forwards;
  }
  .hero-title {
    font-family: 'Cinzel', serif;
    font-weight: 900;
    font-size: clamp(2.4rem, 6vw, 4.5rem);
    letter-spacing: 0.04em;
    line-height: 1.1;
    color: var(--gold-pale);
    margin-bottom: 1.5rem;
    max-width: 800px;
    opacity: 0;
    animation: progFadeUp 0.8s ease 0.4s forwards;
  }
  .hero-highlight {
    color: var(--violet-light, #B48FE0);
    font-style: italic;
  }
  .hero-sub {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(1rem, 2vw, 1.3rem);
    font-style: italic;
    color: var(--text-dim);
    max-width: 580px;
    line-height: 1.7;
    margin-bottom: 3rem;
    opacity: 0;
    animation: progFadeUp 0.8s ease 0.6s forwards;
  }
  .routing-strip {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    justify-content: center;
    margin-bottom: 3.5rem;
    opacity: 0;
    animation: progFadeUp 0.8s ease 0.8s forwards;
  }
  .routing-strip a {
    font-family: 'Space Mono', monospace;
    font-size: 0.6rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-dim);
    border: 0.5px solid rgba(139,116,171,0.25);
    padding: 0.5rem 1rem;
    border-radius: 2px;
    text-decoration: none;
    transition: all 0.2s;
  }
  .routing-strip a:hover {
    color: var(--violet-light, #B48FE0);
    border-color: rgba(180,143,224,0.5);
  }
  .scroll-hint {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    font-family: 'Space Mono', monospace;
    font-size: 0.52rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(240,236,248,0.2);
    opacity: 0;
    animation: progFadeUp 0.8s ease 1.1s forwards;
  }
  .scroll-line {
    width: 0.5px;
    height: 36px;
    background: rgba(240,236,248,0.15);
  }

  /* ── ECOSYSTEM ── */
  #ecosystem {
    padding: 6rem 2rem;
    text-align: center;
    position: relative;
  }
  .ecosystem-nebula {
    position: absolute;
    top: 20%; left: -10%;
    width: 500px; height: 500px;
    background: radial-gradient(ellipse, rgba(107,63,160,0.08) 0%, transparent 65%);
    pointer-events: none;
  }
  .ecosystem-nebula-2 {
    position: absolute;
    bottom: 10%; right: -5%;
    width: 400px; height: 400px;
    background: radial-gradient(ellipse, rgba(139,92,200,0.07) 0%, transparent 65%);
    pointer-events: none;
  }
  .ecosystem-cards {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    max-width: 900px;
    margin: 0 auto;
    text-align: left;
    position: relative;
    z-index: 1;
  }
  .eco-card {
    background: rgba(255,255,255,0.02);
    border: 0.5px solid var(--border-dim);
    border-radius: 4px;
    padding: 2rem 2.25rem;
    transition: border-color 0.2s;
    position: relative;
    overflow: hidden;
  }
  .eco-card:hover { border-color: rgba(139,116,171,0.35); }
  .eco-ring {
    position: absolute;
    top: -60px; right: -60px;
    width: 200px; height: 200px;
    border-radius: 50%;
    border: 0.5px solid rgba(139,116,171,0.08);
    pointer-events: none;
  }
  .eco-glyph {
    font-size: 1.5rem;
    color: rgba(139,116,171,0.4);
    margin-bottom: 0.75rem;
    line-height: 1;
  }
  .eco-glyph--menagerie { color: rgba(180,143,224,0.5); }
  .eco-tag {
    font-family: 'Space Mono', monospace;
    font-size: 0.55rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--teal);
    margin-bottom: 0.5rem;
  }
  .eco-label {
    font-family: 'Cinzel', serif;
    font-size: 1.1rem;
    letter-spacing: 0.06em;
    color: var(--text);
    margin-bottom: 0.75rem;
  }
  .eco-desc {
    font-size: 0.9rem;
    color: var(--text-dim);
    line-height: 1.75;
    margin-bottom: 0.75rem;
    max-width: 560px;
  }
  .eco-bm-note, .eco-edu-note {
    font-family: 'Space Mono', monospace;
    font-size: 0.55rem;
    letter-spacing: 0.08em;
    color: rgba(240,236,248,0.25);
    margin-top: 0.5rem;
  }

  /* FLIP + Educators wide cards */
  .eco-card--fllip {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: 2rem;
  }
  .eco-card--educators { border-color: rgba(107,63,160,0.25); }
  .eco-fllip-left { display: flex; flex-direction: column; }
  .eco-fllip-right { display: flex; flex-direction: column; justify-content: center; gap: 1rem; }

  .fllip-acronym {
    display: flex;
    gap: 1rem;
    margin-top: 0.75rem;
  }
  .fllip-letter {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.2rem;
  }
  .fl-big {
    font-family: 'Cinzel', serif;
    font-size: 1.6rem;
    font-weight: 900;
    color: var(--violet-light, #B48FE0);
    line-height: 1;
  }
  .fl-word {
    font-family: 'Space Mono', monospace;
    font-size: 0.45rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(240,236,248,0.3);
  }
  .eco-stats {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
    margin: 0.5rem 0;
  }
  .eco-stat { display: flex; flex-direction: column; gap: 0.15rem; }
  .eco-num {
    font-family: 'Cinzel', serif;
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--violet-light, #B48FE0);
    line-height: 1;
  }
  .eco-stat-label {
    font-family: 'Space Mono', monospace;
    font-size: 0.5rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-faint);
  }

  /* ── ABC LORE ── */
  #lore {
    padding: 5rem 2rem;
    border-top: 0.5px solid var(--border-dim);
    text-align: center;
  }
  .portal-abc-inner {
    max-width: 960px;
    margin: 0 auto;
  }
  .portal-abc-sub {
    font-size: 0.95rem;
    color: var(--text-dim);
    line-height: 1.8;
    max-width: 640px;
    margin: 0 auto 2.5rem;
  }
  .abc-strip {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    border: 0.5px solid var(--border-dim);
    border-radius: 3px;
    overflow: hidden;
    margin-bottom: 1.5rem;
  }
  .abc-cell {
    padding: 1.25rem 0.75rem;
    border-right: 0.5px solid var(--border-dim);
    text-align: center;
    transition: background 0.2s;
  }
  .abc-cell:last-child { border-right: none; }
  .abc-cell:hover { background: rgba(107,63,160,0.06); }
  .abc-letter {
    display: block;
    font-family: 'Cinzel', serif;
    font-size: 1.5rem;
    font-weight: 900;
    color: var(--violet-light, #B48FE0);
    margin-bottom: 0.4rem;
  }
  .abc-word {
    display: block;
    font-family: 'Space Mono', monospace;
    font-size: 0.5rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text);
    margin-bottom: 0.5rem;
  }
  .abc-desc {
    display: block;
    font-size: 0.75rem;
    color: var(--text-dim);
    line-height: 1.5;
  }

  /* ── COHORT BRIDGE ── */
  #cohort-bridge {
    padding: 5rem 2rem;
    border-top: 0.5px solid var(--border-dim);
    text-align: center;
  }
  .cohort-bridge-inner {
    max-width: 620px;
    margin: 0 auto;
  }
  .cohort-bridge-eyebrow {
    font-family: 'Space Mono', monospace;
    font-size: 0.58rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--violet-light, #B48FE0);
    margin-bottom: 0.75rem;
  }
  .cohort-bridge-heading {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 500;
    color: var(--text);
    margin-bottom: 1rem;
    line-height: 1.2;
  }
  .cohort-bridge-body {
    font-size: 0.95rem;
    color: var(--text-dim);
    line-height: 1.8;
    margin-bottom: 2rem;
  }
  .cohort-bridge-ctas {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 768px) {
    #hero { min-height: 80vh; padding: 5rem 1.5rem 3rem; }
    #ecosystem, #lore, #cohort-bridge { padding: 4rem 1.5rem; }
    .eco-card--fllip { grid-template-columns: 1fr; gap: 1.25rem; }
    .abc-strip { grid-template-columns: repeat(4, 1fr); }
    .abc-cell:nth-child(4) { border-right: none; }
    .abc-cell:nth-child(n+5) { border-top: 0.5px solid var(--border-dim); }
    .abc-cell:nth-child(7) { grid-column: span 4; }
  }
  @media (max-width: 480px) {
    .hero-title { font-size: clamp(2rem, 8vw, 3rem); }
    .routing-strip { gap: 0.4rem; }
    .routing-strip a { font-size: 0.52rem; padding: 0.4rem 0.75rem; }
    .abc-strip { grid-template-columns: 1fr 1fr; }
    .abc-cell:nth-child(2n) { border-right: none; }
    .abc-cell:nth-child(n+3) { border-top: 0.5px solid var(--border-dim); }
    .abc-cell:nth-child(7) { grid-column: span 2; }
  }
</style>
