---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Quest Labs — Enter the Portal">

<!-- ===== HERO ===== -->
<section id="hero">
  <div class="hero-glow"></div>
  <div class="hero-glow-2"></div>
  <div class="portal-ring"></div>
  <div class="portal-ring"></div>
  <div class="portal-ring"></div>

  <p class="hero-eyebrow">Quest Labs · Afrofuturist Methodology · Est. 2022</p>
  <h1 class="hero-title">The Future Is Not<br>Predicted. It Is <span class="hero-highlight">Played.</span></h1>
  <p class="hero-sub">A living laboratory for futures literacy, healing-centered design, and the art of navigating what hasn't happened yet.</p>

  <div class="hero-actions">
    <a href="#futures-portal" class="btn-primary">Enter the Portal</a>
    <a href="#ecosystem" class="btn-secondary">Join the Ecosystem</a>
  </div>

  <div class="scroll-hint">
    <div class="scroll-line"></div>
    <span>Scroll to Begin</span>
  </div>
</section>

<!-- ===== FUTURES TRIANGLE LIVE EXPERIENCE ===== -->
<section id="futures-portal">
  <p class="section-eyebrow">Free Entry Point · Futures Triangle</p>
  <h2 class="section-title">What World Are You From?</h2>
  <p class="section-sub">Pick a lens. Answer one question. Your response joins a living map of collective futures intelligence.</p>

  <div class="triangle-container">
    <div class="triangle-cards">
      <div class="tri-card drivers" data-type="drivers" onclick="selectCard(this)">
        <span class="tri-glyph">⚡</span>
        <div class="tri-label">Drivers</div>
        <div class="tri-desc">Forces accelerating change — what's pushing us forward whether we want it or not</div>
      </div>
      <div class="tri-card weights" data-type="weights" onclick="selectCard(this)">
        <span class="tri-glyph">⚖️</span>
        <div class="tri-label">Weights</div>
        <div class="tri-desc">Resistances and anchors — what's holding systems in place, for better or worse</div>
      </div>
      <div class="tri-card visions" data-type="visions" onclick="selectCard(this)">
        <span class="tri-glyph">✦</span>
        <div class="tri-label">Visions</div>
        <div class="tri-desc">Images of the desired — what futures are worth building, worth protecting, worth dreaming</div>
      </div>
    </div>

    <div class="futures-prompt-area" id="promptArea">
      <div class="prompt-instruction">Select a card above to receive your futures prompt</div>
      <div class="prompt-text" id="promptText">Choose your lens to begin...</div>
      <div class="prompt-input-row">
        <input class="prompt-input" id="promptInput" type="text" placeholder="Your response seeds the collective map..." disabled>
        <button class="prompt-submit" id="promptSubmit" onclick="submitWord()" disabled>Contribute →</button>
      </div>
    </div>

    <div class="wordcloud-section">
      <div class="wordcloud-header">
        <span class="wordcloud-label">Collective Intelligence Map · All Contributors</span>
        <span class="live-dot">Live</span>
      </div>
      <div id="wordcloud-canvas"></div>
      <div class="contribution-count">
        <span id="contrib-count">847</span> contributions from educators across 23 countries
      </div>
    </div>
  </div>
</section>

<!-- ===== JOIN THE ECOSYSTEM ===== -->
<section id="ecosystem">
  <div class="ecosystem-nebula"></div>
  <div class="ecosystem-nebula-2"></div>

  <p class="section-eyebrow">You've Crossed the Threshold · Three Orbits</p>
  <h2 class="section-title">Join the Ecosystem</h2>
  <p class="section-sub">The portal is open. Now choose your orbit — from open exploration to deep immersion.</p>

  <div class="ecosystem-cards">

    <div class="eco-card">
      <div class="eco-ring"></div>
      <div class="eco-glyph">◯</div>
      <div class="eco-tag">Free · Monthly · Open Door</div>
      <h3 class="eco-label">Sandbox Sessions</h3>
      <p class="eco-desc">Monthly, Open Door gatherings on Luma. Free + Donations. Come as you are. Leave with a futures prompt in your pocket.</p>
      <a href="#" class="btn-primary">Find a Session →</a>
    </div>

    <div class="eco-card">
      <div class="eco-ring"></div>
      <div class="eco-glyph">✦</div>
      <div class="eco-tag">Open Knowledge · Collective</div>
      <h3 class="eco-label">Digital Garden</h3>
      <p class="eco-desc">Plant seeds in the Living Knowledgebase. Zettelkasten method. We all feed this. Every node connects.</p>
      <a href="#" class="btn-primary">Enter the Garden →</a>
    </div>

    <div class="eco-card eco-card--fllip">
      <div class="eco-ring"></div>
      <div class="eco-fllip-left">
        <div class="eco-glyph">◈</div>
        <div class="eco-tag">Flagship 2026 · By Invitation</div>
        <h3 class="eco-label">FLLIP Cohorts</h3>
        <div class="fllip-acronym eco-fllip-acronym">
          <div class="fllip-letter"><span class="fl-big">F</span><span class="fl-word">Futures</span></div>
          <div class="fllip-letter"><span class="fl-big">L</span><span class="fl-word">Literacies</span></div>
          <div class="fllip-letter"><span class="fl-big">L</span><span class="fl-word">Leadership</span></div>
          <div class="fllip-letter"><span class="fl-big">I</span><span class="fl-word">Invitation</span></div>
          <div class="fllip-letter"><span class="fl-big">P</span><span class="fl-word">Program</span></div>
        </div>
      </div>
      <div class="eco-fllip-right">
        <p class="eco-desc" style="max-width:none; text-align:left;">Twelve weeks of embodied, participatory, healing-centered methodology. For educational leaders ready to stop reacting — and start authoring the future.</p>
        <div class="eco-stats">
          <div class="eco-stat"><span class="eco-num">12</span><span class="eco-stat-label">Weeks</span></div>
          <div class="eco-stat"><span class="eco-num">5</span><span class="eco-stat-label">Founding Questors</span></div>
          <div class="eco-stat"><span class="eco-num">7</span><span class="eco-stat-label">Literacies</span></div>
          <div class="eco-stat"><span class="eco-num">∞</span><span class="eco-stat-label">Possible Futures</span></div>
        </div>
        <a href="/program" class="btn-primary" style="align-self:flex-start;">Accept the Invitation →</a>
      </div>
    </div>

  </div>
</section>

<!-- ===== ABCDEFG LORE ===== -->
<section id="lore">
  <div class="lore-grid">
    <div class="lore-text">
      <p class="section-eyebrow">The Framework · ABCDEFG</p>
      <h2 class="section-title">Seven Literacies for a World in Transition</h2>
      <p>The futures are not missing. They've been <em>confiscated</em>. Decades of deficit-model education trained whole generations to react to crises rather than author alternatives — to manage uncertainty rather than inhabit it with skill.</p>
      <p>Quest Labs builds the <strong>infrastructure for what comes next</strong>. Not retrofitted onto broken systems. Built from scratch, from the ground up, with community wisdom as the foundation.</p>
      <p>The <strong>ABCDEFG Futures Literacies Framework</strong> emerged from 545 contributions by 170 educators across two healing-centered gatherings. It is not a curriculum. It is a living methodology — seven interlocking capacities that, together, form a complete ecology of futures intelligence.</p>
      <p>This is shadow work and emergence work. The archaeology of self <em>and</em> the bridge to thriving. Both at once.</p>
      <a href="/science" class="btn-secondary" style="display:inline-block; margin-top:16px;">Explore the Science</a>
    </div>

    <div class="lore-visual">
      <div class="abcdefg-radial" id="radialChart"></div>
    </div>
  </div>
</section>

<!-- FOOTER -->
<footer>
  <div class="footer-inner">
    <div>
      <div class="footer-logo">Quest Labs</div>
      <div class="footer-tagline">Healing-Centered Futures for Educational Leaders</div>
    </div>
    <ul class="footer-links">
      <li><a href="#">FLLIP</a></li>
      <li><a href="#">ABCDEFG Framework</a></li>
      <li><a href="#">Mosaics in the Making</a></li>
      <li><a href="#">Soul Center Collective</a></li>
      <li><a href="/science">Research</a></li>
      <li><a href="#">Contact</a></li>
    </ul>
  </div>
  <div class="footer-copy">© 2026 Quest Labs · Makēda · All futures reserved · Berlin & Beyond</div>
</footer>

<script is:inline>
// ===== ABCDEFG RADIAL =====
const radial = document.getElementById('radialChart');
const letters = [
  { l: 'A', w: 'Affective', color: '#e8621a', angle: -90 },
  { l: 'B', w: 'Behavioral', color: '#d4a017', angle: -38 },
  { l: 'C', w: 'Cognitive', color: '#0fb8a0', angle: 14 },
  { l: 'D', w: 'Dialectical', color: '#c4446c', angle: 66 },
  { l: 'E', w: 'Experiential', color: '#7c3aed', angle: 118 },
  { l: 'F', w: 'Fun/Creative', color: '#0fb8a0', angle: 170 },
  { l: 'G', w: 'Generative', color: '#d4a017', angle: 222 }
];
const radius = 118;
letters.forEach(item => {
  const rad = (item.angle * Math.PI) / 180;
  const x = 160 + radius * Math.cos(rad);
  const y = 160 + radius * Math.sin(rad);

  const line = document.createElement('div');
  line.className = 'radial-line';
  const dist = radius - 40;
  line.style.cssText = `width:${dist}px; transform-origin: left center; transform: rotate(${item.angle}deg); left: 160px; top: 160px; background: linear-gradient(90deg, rgba(${hexToRgb(item.color)},0.3) 0%, transparent 100%);`;
  radial.appendChild(line);

  const node = document.createElement('div');
  node.className = 'radial-node';
  node.style.cssText = `left: ${x}px; top: ${y}px; border-color: ${item.color}40; --node-transform: translate(-50%,-50%); transform: translate(-50%,-50%);`;
  node.innerHTML = `<span class="nl" style="color:${item.color}">${item.l}</span><span class="nw">${item.w}</span>`;
  node.title = item.w;
  radial.appendChild(node);
});

const center = document.createElement('div');
center.className = 'radial-center';
center.textContent = 'FLF';
radial.appendChild(center);

function hexToRgb(hex) {
  const r = parseInt(hex.slice(1,3),16), g = parseInt(hex.slice(3,5),16), b = parseInt(hex.slice(5,7),16);
  return `${r},${g},${b}`;
}

// ===== FUTURES TRIANGLE =====
const prompts = {
  drivers: [
    "In one word — what force is reshaping education right now, whether we want it to or not?",
    "Name the signal of change you see every day that most people are still ignoring.",
    "What's accelerating? One word from your classroom, your community, your gut."
  ],
  weights: [
    "What's holding the system in place? Name the anchor — one word.",
    "What belief or structure slows down the change that needs to happen?",
    "In one word: what are we most afraid to let go of?"
  ],
  visions: [
    "Name the world you're building toward. One word.",
    "What does a thriving future feel like? Give it a word.",
    "One word for what education could be, in the world you want to inhabit."
  ]
};

let selectedType = null;

function selectCard(card) {
  document.querySelectorAll('.tri-card').forEach(c => c.classList.remove('active'));
  card.classList.add('active');
  selectedType = card.dataset.type;
  const list = prompts[selectedType];
  const currentPrompt = list[Math.floor(Math.random() * list.length)];
  document.getElementById('promptText').textContent = currentPrompt;
  document.getElementById('promptInput').disabled = false;
  document.getElementById('promptInput').placeholder = 'One word or short phrase...';
  document.getElementById('promptSubmit').disabled = false;
}

// ===== WORD CLOUD =====
const seedWords = [
  { text: 'belonging', size: 28, color: '#b0a3c8' },
  { text: 'uncertainty', size: 22, color: '#8B74AB' },
  { text: 'joy', size: 36, color: '#f0ecf8' },
  { text: 'extractive', size: 16, color: '#7b65a0' },
  { text: 'imagination', size: 30, color: '#c9bedd' },
  { text: 'healing', size: 26, color: '#b0a3c8' },
  { text: 'disruption', size: 18, color: '#8B74AB' },
  { text: 'thriving', size: 32, color: '#f0ecf8' },
  { text: 'equity', size: 24, color: '#9a87bb' },
  { text: 'emergence', size: 20, color: '#b0a3c8' },
  { text: 'audacity', size: 34, color: '#c9bedd' },
  { text: 'rest', size: 16, color: '#8E8E9A' },
  { text: 'ancestors', size: 22, color: '#8B74AB' },
  { text: 'abundance', size: 26, color: '#b0a3c8' },
  { text: 'futures', size: 38, color: '#f0ecf8' },
  { text: 'decolonial', size: 18, color: '#9a87bb' },
  { text: 'play', size: 30, color: '#c9bedd' },
  { text: 'transformation', size: 14, color: '#8E8E9A' },
  { text: 'community', size: 28, color: '#b0a3c8' },
  { text: 'now', size: 20, color: '#8B74AB' }
];

let cloudWords = [...seedWords];
let contribCount = 847;

function renderWordCloud() {
  const container = document.getElementById('wordcloud-canvas');
  container.innerHTML = '';
  const w = container.offsetWidth || 880;
  const h = 240;
  const placed = [];

  cloudWords.slice().sort((a, b) => b.size - a.size).forEach(word => {
    const el = document.createElement('div');
    el.className = 'cloud-word';
    el.textContent = word.text;
    el.style.fontSize = word.size + 'px';
    el.style.color = word.color;
    el.style.opacity = 0.15 + (word.size / 40) * 0.85;
    container.appendChild(el);

    let tries = 0, placed_ = false;
    const ew = word.text.length * word.size * 0.55;
    const eh = word.size * 1.3;
    while (tries < 80 && !placed_) {
      const x = Math.random() * (w - ew);
      const y = Math.random() * (h - eh);
      const overlap = placed.some(p =>
        x < p.x + p.w + 8 && x + ew + 8 > p.x &&
        y < p.y + p.h + 4 && y + eh + 4 > p.y
      );
      if (!overlap) {
        el.style.left = x + 'px';
        el.style.top = y + 'px';
        placed.push({ x, y, w: ew, h: eh });
        placed_ = true;
      }
      tries++;
    }
    if (!placed_) {
      el.style.left = Math.random() * (w - ew) + 'px';
      el.style.top = Math.random() * (h - eh) + 'px';
    }
  });
}

function submitWord() {
  const input = document.getElementById('promptInput');
  const val = input.value.trim().toLowerCase().split(/\s+/)[0];
  if (!val || val.length < 2) return;

  const colors = ['#f0ecf8', '#b0a3c8', '#8B74AB', '#c9bedd', '#9a87bb', '#8E8E9A'];
  cloudWords.push({
    text: val,
    size: 18 + Math.floor(Math.random() * 14),
    color: colors[Math.floor(Math.random() * colors.length)]
  });

  contribCount++;
  document.getElementById('contrib-count').textContent = contribCount.toLocaleString();

  input.value = '';
  input.placeholder = 'Your word joined the map ✦';
  setTimeout(() => { input.placeholder = 'One word or short phrase...'; }, 2500);

  renderWordCloud();
}

document.getElementById('promptInput').addEventListener('keydown', e => {
  if (e.key === 'Enter') submitWord();
});

setTimeout(renderWordCloud, 400);
window.addEventListener('resize', () => setTimeout(renderWordCloud, 200));
</script>

</Layout>
