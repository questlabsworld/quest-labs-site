---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Quest Labs, Enter the Portal">

<!-- ===== HERO ===== -->
<section id="hero">
  <div class="hero-glow"></div>
  <div class="hero-glow-2"></div>
  <div class="portal-ring"></div>
  <div class="portal-ring"></div>
  <div class="portal-ring"></div>

  <p class="hero-eyebrow">Quest Labs · Healing-Centered Futures · Est. 2022</p>
  <h1 class="hero-title">The Future Is Not<br>Predicted. It Is <span class="hero-highlight">Played.</span></h1>
  <p class="hero-sub">A living lab for the art of navigating the unknown.</p>
  <p class="hero-sub hero-sub--2">Built for people who refuse to keep preparing for a world that no longer exists.</p>
  <div class="hero-ctas">
    <a href="#ecosystem" class="cta-primary">Find your entry point →</a>
    <a href="/educators" class="cta-secondary">I'm an educator</a>
  </div>
</section>

<!-- ===== WHERE DO YOU BELONG ===== -->
<section id="ecosystem">
  <div class="ecosystem-nebula"></div>
  <div class="ecosystem-nebula-2"></div>

  <h2 class="eco-heading">Where do you belong in this ecosystem?</h2>

  <div class="ecosystem-cards">

    <div class="eco-card">
      <div class="eco-emoji">🌱</div>
      <div class="eco-intent">I just want to peek into the unknown right now.</div>
      <h3 class="eco-label">Sandbox Sessions</h3>
      <p class="eco-desc">Monthly, open door, donations based. Come once. Come back. No commitment required.</p>
      <a href="https://lu.ma/questlabs" class="eco-cta" target="_blank" rel="noopener noreferrer">Find a session →</a>
    </div>

    <div class="eco-card">
      <div class="eco-emoji">🔥</div>
      <div class="eco-intent">I want the full arc</div>
      <h3 class="eco-label">FLIP Cohorts</h3>
      <p class="eco-desc">12 weeks, embodied. Cohort 01 is full and in motion. Cohort 02 is now forming.</p>
      <a href="/program#waitlist" class="eco-cta">Join the waitlist →</a>
    </div>

    <div class="eco-card">
      <div class="eco-emoji">📚</div>
      <div class="eco-intent">I'm an educator</div>
      <h3 class="eco-label">Flip the Script</h3>
      <p class="eco-desc">Built for teachers, coaches, and school leaders. Join the fall cohort or bring this to your school.</p>
      <a href="/educators" class="eco-cta">Educators, this way →</a>
    </div>

    <div class="eco-card">
      <div class="eco-emoji">💛</div>
      <div class="eco-intent">I want to fund what matters</div>
      <h3 class="eco-label">Sponsor the Work</h3>
      <p class="eco-desc">20 sponsored seats available for the Fall 2026 founding cohort. Or support the ecosystem directly.</p>
      <a href="/contact" class="eco-cta">Let's talk →</a>
    </div>

  </div>
</section>

<!-- ===== ABCs FOR FUTURES LITERACIES ===== -->
<section id="lore">
  <div class="portal-abc-inner">
    <p class="section-eyebrow">ABCs for Futures Literacies</p>
    <h2 class="section-title">Seven Literacies for a World in Transition</h2>
    <p class="portal-abc-sub">Most futures literacy frameworks center cognitive sense-making. The ABCs for Futures Literacies framework works across a fuller set of dimensions. Embodied futures asks something different of people. That pause is the point.</p>
    <div class="abc-strip portal-abc-strip">
      <div class="abc-cell"><span class="abc-letter">A</span><span class="abc-word">Affective</span><span class="abc-desc">Emotional intelligence · feeling states · mood · emotional processing</span></div>
      <div class="abc-cell"><span class="abc-letter">B</span><span class="abc-word">Behavioral</span><span class="abc-desc">Actions · practices · habits · rituals · repeated behaviors</span></div>
      <div class="abc-cell"><span class="abc-letter">C</span><span class="abc-word">Cognitive</span><span class="abc-desc">Thinking · analysis · knowledge · understanding · mental processing</span></div>
      <div class="abc-cell"><span class="abc-letter">D</span><span class="abc-word">Dialectical</span><span class="abc-desc">Tensions · contradictions · both/and thinking · holding complexity</span></div>
      <div class="abc-cell"><span class="abc-letter">E</span><span class="abc-word">Embodied / Experiential</span><span class="abc-desc">Direct engagement · learning through experience · participatory practice</span></div>
      <div class="abc-cell"><span class="abc-letter">F</span><span class="abc-word">Fun / Creative</span><span class="abc-desc">Play · imagination · joy · creativity · experimentation</span></div>
      <div class="abc-cell"><span class="abc-letter">G</span><span class="abc-word">Generative</span><span class="abc-desc">Creating · midwiving new possibilities · hospicing toward transformation</span></div>
    </div>
    <a href="/foundations" class="btn-secondary" style="display:inline-block; margin-top:1.5rem;">Explore the Foundations</a>
  </div>
</section>

<!-- ===== COHORT 02 BRIDGE ===== -->
<section id="cohort-bridge">
  <div class="cohort-bridge-inner">
    <p class="cohort-bridge-eyebrow">Cohort 02 · Now Forming</p>
    <h2 class="cohort-bridge-heading">Ready to go deeper?</h2>
    <p class="cohort-bridge-body">FLIP, the Futures Literacies Invitational Playground, is a 12-week embodied journey toward your 2032 self. The founding cohort is full and already in motion. Cohort 02 is now forming.</p>
    <div class="cohort-bridge-ctas">
      <a href="/program#waitlist" class="btn-primary">Join the Cohort 02 waitlist →</a>
      <a href="/program" class="btn-secondary">Explore the program →</a>
    </div>
  </div>
</section>

<div class="page-bridge" style="max-width:860px; margin-left:auto; margin-right:auto; padding-left:2.5rem; padding-right:2.5rem;">
  <p>Not sure where to start?</p>
  <a href="https://lu.ma/questlabs" class="bridge-link">Find a Sandbox Session, open door, no commitment →</a>
</div>

<!-- FOOTER -->
<footer>
  <div class="footer-inner">
    <div>
      <div class="footer-logo">Quest Labs</div>
      <div class="footer-tagline">Healing-Centered Futures</div>
    </div>
    <ul class="footer-links">
      <li><a href="/program">FLIP</a></li>
      <li><a href="/educators">Educators</a></li>
      <li><a href="/foundations">Foundations</a></li>
      <li><a href="/black-menagerie">Black Menagerie</a></li>
      <li><a href="/about">About</a></li>
      <li><a href="/contact">Contact</a></li>
    </ul>
  </div>
  <div class="footer-anchor">
    Not sure where to start?
    <a href="https://lu.ma/questlabs">Find a free Sandbox Session →</a>
  </div>
  <div class="footer-copy">2026 Quest Labs · Makēda · All futures reserved · Berlin &amp; Beyond</div>
</footer>




</Layout>

<style>
  /* ── SHARED SECTION TYPOGRAPHY ── */
  .section-eyebrow {
    font-family: 'Space Mono', monospace;
    font-size: 0.6rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--teal);
    margin-bottom: 0.75rem;
  }
  .section-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 500;
    line-height: 1.15;
    color: var(--text);
    margin-bottom: 1rem;
  }
  .section-sub {
    font-size: 1rem;
    color: var(--text-dim);
    line-height: 1.8;
    max-width: 640px;
    margin: 0 auto 3rem;
    text-align: center;
  }

  /* ── HERO ── */
  #hero {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 0.5rem 2rem 2.5rem;
    overflow: hidden;
  }
  .hero-glow {
    position: absolute;
    top: 10%; left: 50%;
    transform: translateX(-50%);
    width: 600px; height: 600px;
    background: radial-gradient(ellipse, rgba(107,63,160,0.18) 0%, transparent 65%);
    pointer-events: none;
    z-index: 0;
  }
  .hero-glow-2 {
    position: absolute;
    bottom: 5%; right: 10%;
    width: 400px; height: 400px;
    background: radial-gradient(ellipse, rgba(139,116,171,0.1) 0%, transparent 65%);
    pointer-events: none;
    z-index: 0;
  }
  .portal-ring {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    border-radius: 50%;
    border: 0.5px solid rgba(139,116,171,0.08);
    pointer-events: none;
    z-index: 0;
  }
  .portal-ring:nth-child(3) { width: 400px; height: 400px; }
  .portal-ring:nth-child(4) { width: 600px; height: 600px; border-color: rgba(139,116,171,0.05); }
  .portal-ring:nth-child(5) { width: 800px; height: 800px; border-color: rgba(139,116,171,0.03); }

  #hero > *:not(.portal-ring):not(.hero-glow):not(.hero-glow-2) { position: relative; z-index: 1; }

  .hero-eyebrow {
    font-family: 'Space Mono', monospace;
    font-size: 0.58rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--teal);
    margin-bottom: 0.75rem;
  }
  .hero-title {
    font-family: 'Cinzel', serif;
    font-weight: 900;
    font-size: clamp(2.4rem, 6vw, 4.5rem);
    letter-spacing: 0.04em;
    line-height: 1.1;
    color: var(--gold-pale);
    margin-bottom: 1.5rem;
    max-width: 800px;
  }
  .hero-highlight {
    color: var(--violet-light, #B48FE0);
    font-style: italic;
  }
  .hero-sub {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(1rem, 2vw, 1.3rem);
    font-style: italic;
    color: var(--text-dim);
    max-width: 580px;
    line-height: 1.7;
    margin-bottom: 0.5rem;
  }
  .hero-sub--2 {
    font-size: clamp(0.85rem, 1.6vw, 1.05rem);
    margin-bottom: 2.5rem;
    opacity: 0.7;
  }
  /* Hero entry CTAs */
  .hero-ctas {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 0.5rem;
  }
  .cta-primary {
    display: inline-block;
    padding: 0.65rem 1.4rem;
    background: var(--violet, #6B3FA0);
    color: var(--text, #f0ecf8);
    border-radius: 6px;
    text-decoration: none;
    font-weight: 500;
    font-size: 0.95rem;
    line-height: 1.4;
  }
  .cta-primary:hover { background: var(--violet-mid, #8B5CC8); }
  .cta-secondary {
    display: inline-block;
    padding: 0.65rem 1.4rem;
    border: 1.5px solid rgba(240, 236, 248, 0.6);
    border-radius: 6px;
    text-decoration: none;
    font-size: 0.95rem;
    color: var(--text, #f0ecf8);
    line-height: 1.4;
  }
  .cta-secondary:hover { border-color: var(--text); }

  /* Hero CTA */
  .hero-cta-primary {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    font-family: 'Space Mono', monospace;
    font-size: 0.78rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text);
    background: var(--violet, #6B3FA0);
    padding: 1rem 2.25rem 0.85rem;
    border-radius: 2px;
    text-decoration: none;
    transition: background 0.2s;
    margin-bottom: 1.25rem;
    opacity: 0;
    animation: progFadeUp 0.8s ease 0.8s forwards;
  }
  .hero-cta-primary:hover { background: var(--violet-mid, #8B5CC8); }
  .hero-cta-note {
    font-family: 'Mulish', sans-serif;
    font-size: 0.7rem;
    letter-spacing: 0.04em;
    text-transform: none;
    color: rgba(240,236,248,0.55);
    font-weight: 400;
  }
  .hero-secondary-line {
    font-family: 'Space Mono', monospace;
    font-size: 0.58rem;
    letter-spacing: 0.14em;
    color: rgba(240,236,248,0.3);
    margin-bottom: 1rem;
    opacity: 0;
    animation: progFadeUp 0.8s ease 1s forwards;
  }

  /* ── ECOSYSTEM ── */
  #ecosystem {
    padding: 4rem 2rem 5rem;
    position: relative;
    border-top: 0.5px solid var(--border-dim);
  }
  .ecosystem-nebula {
    position: absolute;
    top: 20%; left: -10%;
    width: 500px; height: 500px;
    background: radial-gradient(ellipse, rgba(107,63,160,0.07) 0%, transparent 65%);
    pointer-events: none;
  }
  .ecosystem-nebula-2 {
    position: absolute;
    bottom: 10%; right: -5%;
    width: 400px; height: 400px;
    background: radial-gradient(ellipse, rgba(139,92,200,0.05) 0%, transparent 65%);
    pointer-events: none;
  }
  .eco-heading {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(1.5rem, 3vw, 2.2rem);
    font-weight: 500;
    color: var(--text-dim);
    text-align: center;
    margin-bottom: 2.5rem;
    font-style: italic;
  }
  .ecosystem-cards {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
    max-width: 860px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }
  .eco-card {
    background: rgba(255,255,255,0.02);
    border: 0.5px solid var(--border-dim);
    border-radius: 4px;
    padding: 1.75rem;
    transition: border-color 0.2s, background 0.2s;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .eco-card:hover { border-color: rgba(139,116,171,0.4); background: rgba(107,63,160,0.04); }
  .eco-emoji {
    font-size: 1.5rem;
    line-height: 1;
    margin-bottom: 0.25rem;
  }
  .eco-intent {
    font-family: 'Space Mono', monospace;
    font-size: 0.58rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--teal);
  }
  .eco-label {
    font-family: 'Cinzel', serif;
    font-size: 1rem;
    letter-spacing: 0.05em;
    color: var(--text);
    margin-top: 0.1rem;
  }
  .eco-desc {
    font-size: 0.88rem;
    color: var(--text-dim);
    line-height: 1.7;
    flex: 1;
  }
  .eco-cta {
    font-family: 'Space Mono', monospace;
    font-size: 0.6rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--violet-light, #B48FE0);
    text-decoration: none;
    margin-top: 0.5rem;
    transition: color 0.2s;
  }
  .eco-cta:hover { color: var(--text); }

  /* ── ABC LORE ── */
  #lore {
    padding: 5rem 2rem;
    border-top: 0.5px solid var(--border-dim);
    text-align: center;
  }
  .portal-abc-inner {
    max-width: 960px;
    margin: 0 auto;
  }
  .portal-abc-sub {
    font-size: 0.95rem;
    color: var(--text-dim);
    line-height: 1.8;
    max-width: 640px;
    margin: 0 auto 2.5rem;
  }
  .abc-strip {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    border: 0.5px solid var(--border-dim);
    border-radius: 3px;
    overflow: hidden;
    margin-bottom: 1.5rem;
  }
  .abc-cell {
    padding: 1.25rem 0.75rem;
    border-right: 0.5px solid var(--border-dim);
    text-align: center;
    transition: background 0.2s;
  }
  .abc-cell:last-child { border-right: none; }
  .abc-cell:hover { background: rgba(107,63,160,0.06); }
  .abc-letter {
    display: block;
    font-family: 'Cinzel', serif;
    font-size: 1.5rem;
    font-weight: 900;
    color: var(--violet-light, #B48FE0);
    margin-bottom: 0.4rem;
  }
  .abc-word {
    display: block;
    font-family: 'Space Mono', monospace;
    font-size: 0.5rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text);
    margin-bottom: 0.5rem;
  }
  .abc-desc {
    display: block;
    font-size: 0.75rem;
    color: var(--text-dim);
    line-height: 1.5;
  }

  /* ── COHORT BRIDGE ── */
  #cohort-bridge {
    padding: 5rem 2rem;
    border-top: 0.5px solid var(--border-dim);
    text-align: center;
  }
  .cohort-bridge-inner {
    max-width: 620px;
    margin: 0 auto;
  }
  .cohort-bridge-eyebrow {
    font-family: 'Space Mono', monospace;
    font-size: 0.58rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--violet-light, #B48FE0);
    margin-bottom: 0.75rem;
  }
  .cohort-bridge-heading {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 500;
    color: var(--text);
    margin-bottom: 1rem;
    line-height: 1.2;
  }
  .cohort-bridge-body {
    font-size: 0.95rem;
    color: var(--text-dim);
    line-height: 1.8;
    margin-bottom: 2rem;
  }
  .cohort-bridge-ctas {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 768px) {
    #hero { padding: 3rem 1.5rem 2.5rem; }
    #ecosystem, #lore, #cohort-bridge { padding: 3rem 1.5rem; }
    .ecosystem-cards { grid-template-columns: 1fr; }
    .abc-strip { grid-template-columns: repeat(4, 1fr); }
    .abc-cell:nth-child(4) { border-right: none; }
    .abc-cell:nth-child(n+5) { border-top: 0.5px solid var(--border-dim); }
    .abc-cell:nth-child(7) { grid-column: span 4; }
  }
  @media (max-width: 480px) {
    .hero-title { font-size: clamp(2rem, 8vw, 3rem); }
    .hero-cta-primary { width: 100%; text-align: center; }
    .abc-strip { grid-template-columns: 1fr 1fr; }
    .abc-cell:nth-child(2n) { border-right: none; }
    .abc-cell:nth-child(n+3) { border-top: 0.5px solid var(--border-dim); }
    .abc-cell:nth-child(7) { grid-column: span 2; }
  }
</style>
