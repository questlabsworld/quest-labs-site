function openModal(id) {
  const data = modalData[id];
  if (!data) return;
  document.getElementById('prog-modal-inner').innerHTML = `
    <div class="prog-modal-tag">${data.tag}</div>
    <div class="prog-modal-title">${data.title}</div>
    <div class="prog-modal-sub">${data.sub}</div>
    <div class="prog-modal-divider"></div>
    <div class="prog-modal-body">${data.body}</div>
    ${data.prompt ? `<div class="prog-modal-prompt-box">${data.prompt}</div>` : ''}
  `;
  document.getElementById('prog-modal').classList.add('active');
  document.body.style.overflow = 'hidden';
}

function closeModal(e) {
  if (!e || e.target === document.getElementById('prog-modal') || (e.target && e.target.classList.contains('prog-modal-close'))) {
    document.getElementById('prog-modal').classList.remove('active');
    document.body.style.overflow = '';
  }
}

document.addEventListener('keydown', e => {
  if (e.key === 'Escape') closeModal({ target: document.getElementById('prog-modal') });
});
