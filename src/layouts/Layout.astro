---
interface Props {
  title: string;
}

const { title } = Astro.props;

const pathname = Astro.url.pathname;

// Returns true when the nav link (or any of its dropdown children) matches the current page
const isActive = (href: string, dropdown?: { href: string }[]): boolean => {
  if (href === '/') return pathname === '/';
  if (pathname === href || pathname.startsWith(href + '/')) return true;
  if (dropdown) return dropdown.some(d => pathname === d.href || pathname.startsWith(d.href + '/'));
  return false;
};

// Human-readable label for the current page (shown near logo as breadcrumb)
const pageLabels: Record<string, string> = {
  '/program':        'FLIP Program',
  '/educators':      'Flip the Script',
  '/foundations':    'Foundations',
  '/about':          'About',
  '/bet':            'Sponsor',
  '/black-menagerie':'Black Menagerie',
  '/contact':        'Contact',
};
const currentPageLabel = pageLabels[pathname] ?? null;

const navLinks = [
  { label: 'Home',       href: '/' },
  { label: 'FLIP',       href: '/program', dropdown: [
      { label: 'Foundations',     href: '/foundations' },
      { label: 'Black Menagerie', href: '/black-menagerie' },
  ]},
  { label: 'Educators',  href: '/educators' },
  { label: 'About',      href: '/about' },
  { label: 'Bet on Us',  href: '/bet' },
];
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700;900&family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Inter:wght@300;400;500&family=Mulish:wght@300;400;600;700&family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700&family=Space+Mono:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet" />

  <style is:global>
    :root {
      --bg:          #000000;
      --void:        #000000;
      --deep:        #1A0B2B;
      --ember:       #453160;
      --gold:        #8B74AB;
      --gold-pale:   #b0a3c8;
      --teal:        #8E8E9A;
      --teal-dark:   #6a6a76;
      --rose:        #453160;
      --violet:      #6B3FA0;
      --violet-mid:  #8B5CC8;
      --violet-light:#B48FE0;
      --mist:        rgba(139, 116, 171, 0.06);
      --fog:         rgba(139, 116, 171, 0.12);
      --text:        #f0ecf8;
      --text-dim:    rgba(240, 236, 248, 0.82);
      --text-faint:  #8E8E9A;
      --border-dim:  rgba(139, 116, 171, 0.15);
    }

    *, *::before, *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    html { scroll-behavior: smooth; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'Mulish', 'Inter', sans-serif;
      font-size: 18px;
      line-height: 1.7;
      overflow-x: hidden;
      padding-top: 112px;
    }

    /* ── STARFIELD ── */
    #starfield {
      position: fixed;
      top: 0; left: 0;
      width: 100%; height: 100%;
      pointer-events: none;
      z-index: 0;
    }

    /* ── NAV ── */
    .site-nav {
      position: fixed;
      top: 0; left: 0;
      width: 100%;
      z-index: 9000;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 2.5rem;
      height: 112px;
      background: rgba(0, 0, 0, 0.7);
      backdrop-filter: blur(14px);
      -webkit-backdrop-filter: blur(14px);
      border-bottom: 0.5px solid rgba(139, 116, 171, 0.12);
      box-sizing: border-box;
    }

    /* Brand: logo + current-page breadcrumb */
    .site-nav__brand {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      flex-shrink: 0;
    }
    .site-nav__logo {
      height: 104px;
      width: auto;
      flex-shrink: 0;
    }
    .site-nav__crumb {
      font-family: 'Space Mono', monospace;
      font-size: 0.65rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: rgba(240, 236, 248, 0.38);
      display: flex;
      align-items: center;
      gap: 0.5rem;
      white-space: nowrap;
    }
    .site-nav__crumb-sep {
      color: rgba(180, 143, 224, 0.35);
    }

    .site-nav__links {
      display: flex;
      list-style: none;
      gap: 2rem;
      margin: 0;
      padding: 0;
      align-items: center;
    }

    .site-nav__link {
      font-family: 'Space Mono', monospace;
      font-size: 0.75rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: rgba(240, 236, 248, 0.62);
      text-decoration: none;
      transition: color 0.2s;
    }

    .site-nav__link:hover {
      color: var(--violet-light, #B48FE0);
    }
    .site-nav__link--active {
      color: #FDFCFA;
      position: relative;
    }
    /* Small dot under active link */
    .site-nav__dot {
      position: absolute;
      bottom: -8px;
      left: 50%;
      transform: translateX(-50%);
      width: 5px;
      height: 5px;
      border-radius: 50%;
      background: #d4aaff;
      box-shadow: 0 0 6px 2px rgba(180, 143, 224, 0.7);
      display: block;
    }
    /* Contact pill */
    .site-nav__contact {
      border: 0.5px solid rgba(107, 63, 160, 0.45);
      border-radius: 2px;
      padding: 0.3rem 0.8rem;
      color: var(--violet-light, #B48FE0) !important;
      transition: background 0.2s, border-color 0.2s !important;
    }
    .site-nav__contact:hover {
      background: rgba(107, 63, 160, 0.15);
      border-color: rgba(180, 143, 224, 0.6);
      color: #FDFCFA !important;
    }
    .site-nav__contact.site-nav__link--active {
      background: rgba(107, 63, 160, 0.2);
      border-color: rgba(180, 143, 224, 0.5);
    }

    /* ── DROPDOWN NAV ── */
    .site-nav__item {
      position: relative;
      list-style: none;
    }

    .site-nav__chevron {
      display: inline-block;
      margin-left: 0.3em;
      font-size: 0.9em;
      opacity: 0.55;
      transition: transform 0.2s, opacity 0.2s;
      vertical-align: middle;
    }
    .has-dropdown:hover .site-nav__chevron {
      transform: rotate(90deg);
      opacity: 1;
    }

    .site-nav__dropdown {
      position: absolute;
      top: calc(100% + 14px);
      left: 50%;
      transform: translateX(-50%) translateY(-6px);
      list-style: none;
      margin: 0;
      padding: 0.5rem 0;
      min-width: 190px;
      background: rgba(8, 4, 18, 0.94);
      backdrop-filter: blur(18px);
      -webkit-backdrop-filter: blur(18px);
      border: 0.5px solid rgba(139, 116, 171, 0.25);
      border-radius: 4px;
      box-shadow: 0 12px 40px rgba(0, 0, 0, 0.6), 0 0 0 0.5px rgba(180, 143, 224, 0.08) inset;
      opacity: 0;
      visibility: hidden;
      transition: opacity 0.22s ease, transform 0.22s ease, visibility 0.22s;
      z-index: 9100;
    }

    /* Subtle top notch */
    .site-nav__dropdown::before {
      content: '';
      position: absolute;
      top: -5px;
      left: 50%;
      transform: translateX(-50%);
      width: 8px;
      height: 8px;
      background: rgba(8, 4, 18, 0.94);
      border-left: 0.5px solid rgba(139, 116, 171, 0.25);
      border-top: 0.5px solid rgba(139, 116, 171, 0.25);
      rotate: 45deg;
    }

    .has-dropdown:hover .site-nav__dropdown {
      opacity: 1;
      visibility: visible;
      transform: translateX(-50%) translateY(0);
    }

    .site-nav__dropdown li {
      list-style: none;
    }

    .site-nav__dropdown-link {
      display: block;
      padding: 0.6rem 1.25rem;
      font-family: 'Space Mono', monospace;
      font-size: 0.68rem;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: rgba(240, 236, 248, 0.58);
      text-decoration: none;
      transition: color 0.18s, background 0.18s;
      white-space: nowrap;
    }
    .site-nav__dropdown-link:hover {
      color: var(--violet-light, #B48FE0);
      background: rgba(107, 63, 160, 0.14);
    }
    .site-nav__dropdown-link.site-nav__link--active {
      color: #FDFCFA;
    }
    /* Thin left accent on active dropdown item */
    .site-nav__dropdown-link.site-nav__link--active::before {
      content: '';
      display: inline-block;
      width: 2px;
      height: 0.75em;
      background: var(--violet-light, #B48FE0);
      border-radius: 1px;
      margin-right: 0.55em;
      vertical-align: middle;
    }

    /* hamburger */
    .site-nav__burger {
      display: none;
      flex-direction: column;
      justify-content: center;
      gap: 5px;
      background: none;
      border: none;
      cursor: pointer;
      padding: 6px;
      z-index: 9001;
    }

    .site-nav__burger span {
      display: block;
      width: 24px;
      height: 2px;
      background: rgba(240, 236, 248, 0.7);
      border-radius: 2px;
      transition: transform 0.3s, opacity 0.3s;
      transform-origin: center;
    }

    .site-nav__burger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
    .site-nav__burger.open span:nth-child(2) { opacity: 0; transform: scaleX(0); }
    .site-nav__burger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

    /* ── GLOBAL SHARED COMPONENTS ── */

    /* Fade-up animation used by hero sections */
    @keyframes progFadeUp {
      from { opacity: 0; transform: translateY(18px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    /* CTA button pair */
    .cta-group {
      display: flex;
      gap: 1rem;
      flex-wrap: wrap;
      align-items: center;
    }

    .cta-primary {
      display: inline-block;
      font-family: 'Space Mono', monospace;
      font-size: 0.7rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--text);
      background: var(--violet, #6B3FA0);
      padding: 0.85rem 2rem;
      text-decoration: none;
      border-radius: 2px;
      transition: background 0.2s;
      cursor: pointer;
      border: none;
    }
    .cta-primary:hover { background: var(--violet-mid, #8B5CC8); }

    .cta-secondary {
      display: inline-block;
      font-family: 'Space Mono', monospace;
      font-size: 0.7rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--text-dim);
      border: 0.5px solid rgba(139, 116, 171, 0.35);
      padding: 0.85rem 2rem;
      text-decoration: none;
      border-radius: 2px;
      transition: all 0.2s;
    }
    .cta-secondary:hover { color: var(--text); border-color: rgba(180,143,224,0.6); }

    /* Old btn- aliases for backward compat */
    .btn-primary  { display: inline-block; font-family: 'Space Mono', monospace; font-size: 0.7rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--text); background: var(--violet, #6B3FA0); padding: 0.85rem 2rem; text-decoration: none; border-radius: 2px; transition: background 0.2s; border: none; cursor: pointer; }
    .btn-primary:hover { background: var(--violet-mid, #8B5CC8); }
    .btn-secondary { display: inline-block; font-family: 'Space Mono', monospace; font-size: 0.7rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--text-dim); border: 0.5px solid rgba(139,116,171,0.35); padding: 0.85rem 2rem; text-decoration: none; border-radius: 2px; transition: all 0.2s; }
    .btn-secondary:hover { color: var(--text); border-color: rgba(180,143,224,0.6); }

    /* Page bridge (cross-page nav block) */
    .page-bridge {
      border-top: 0.5px solid var(--border-dim);
      padding-top: 2rem;
      padding-bottom: 2rem;
      margin-top: 3rem;
    }
    .page-bridge p {
      font-style: italic;
      color: var(--text-dim);
      font-size: 0.95rem;
      margin-bottom: 0.75rem;
    }
    .bridge-link {
      display: block;
      font-family: 'Space Mono', monospace;
      font-size: 0.65rem;
      letter-spacing: 0.1em;
      color: var(--teal);
      text-decoration: none;
      margin-top: 0.25rem;
    }
    .bridge-link:hover { color: var(--gold); }

    /* Global footer */
    footer {
      border-top: 0.5px solid var(--border-dim);
      padding: 3rem 2.5rem 2rem;
      margin-top: 4rem;
    }
    .footer-inner {
      max-width: 1100px;
      margin: 0 auto;
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      flex-wrap: wrap;
      gap: 2rem;
      margin-bottom: 2rem;
    }
    .footer-logo {
      font-family: 'Cinzel', serif;
      font-size: 1rem;
      letter-spacing: 0.15em;
      color: var(--gold-pale);
      margin-bottom: 0.35rem;
    }
    .footer-tagline {
      font-family: 'Space Mono', monospace;
      font-size: 0.6rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--text-faint);
    }
    .footer-links {
      list-style: none;
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem 1.5rem;
    }
    .footer-links a {
      font-family: 'Space Mono', monospace;
      font-size: 0.62rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--text-dim);
      text-decoration: none;
      transition: color 0.2s;
    }
    .footer-links a:hover { color: var(--violet-light); }
    .footer-anchor {
      max-width: 1100px;
      margin: 1rem auto 0;
      font-size: 0.85rem;
      opacity: 0.65;
      padding: 1rem 0;
      border-top: 0.5px solid rgba(240, 236, 248, 0.2);
      font-family: 'Mulish', sans-serif;
    }
    .footer-anchor a {
      color: var(--violet-light);
      text-decoration: none;
    }
    .footer-anchor a:hover { text-decoration: underline; }

    .footer-copy {
      max-width: 1100px;
      margin: 0 auto;
      font-size: 0.7rem;
      color: var(--text-faint);
      font-family: 'Space Mono', monospace;
      letter-spacing: 0.05em;
      padding-top: 1rem;
      border-top: 0.5px solid var(--border-dim);
    }

    /* ── RESPONSIVE ── */
    @media (max-width: 640px) {
      .site-nav { padding: 0 1.25rem; height: 90px; }
      .site-nav__logo { height: 80px; }
      .site-nav__crumb { display: none; }
      .site-nav__burger { display: flex; }

      .site-nav__links {
        display: none;
        position: fixed;
        top: 0; left: 0;
        width: 100%; height: 100vh;
        background: rgba(0, 0, 0, 0.96);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 2.5rem;
        z-index: 9000;
      }

      .site-nav__links.open { display: flex; }

      .site-nav__link {
        font-size: 0.85rem;
        letter-spacing: 0.2em;
      }

      body { padding-top: 90px; }

      footer { padding: 2rem 1.5rem; }
      .footer-inner { flex-direction: column; }
    }

    /* ── TESTIMONIALS CAROUSEL (shared: educators + FLIP) ── */
    .testimonials-section {
      padding: 5rem 2.5rem;
      border-top: 0.5px solid rgba(255,255,255,0.06);
      border-bottom: 0.5px solid rgba(255,255,255,0.06);
      background: rgba(107,63,160,0.04);
    }
    .testimonials-carousel {
      max-width: 700px;
      margin: 0 auto;
      text-align: center;
    }
    .testimonials-track {
      position: relative;
      min-height: 220px;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .testimonial-slide {
      display: none;
      flex-direction: column;
      align-items: center;
      animation: tFade 0.4s ease;
    }
    .testimonial-slide.active { display: flex; }
    @keyframes tFade {
      from { opacity: 0; transform: translateY(8px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .testimonial-quote {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(1.4rem, 3.5vw, 2rem);
      font-style: italic;
      color: #FDFCFA;
      line-height: 1.75;
      margin: 0 0 1.25rem;
    }
    .testimonial-cite {
      font-size: 0.78rem;
      letter-spacing: 0.06em;
      color: #C4A8E8;
      font-style: normal;
      opacity: 0.85;
    }
    .testimonials-controls {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 1.25rem;
      margin-top: 2.5rem;
    }
    .t-btn {
      background: transparent;
      border: 0.5px solid rgba(196,168,232,0.35);
      color: #C4A8E8;
      width: 2.2rem;
      height: 2.2rem;
      border-radius: 50%;
      cursor: pointer;
      font-size: 1rem;
      transition: border-color 0.2s, color 0.2s;
      display: flex;
      align-items: center;
      justify-content: center;
      line-height: 1;
    }
    .t-btn:hover { border-color: #C4A8E8; color: #FDFCFA; }
    .t-dots { display: flex; gap: 0.5rem; align-items: center; }
    .t-dot {
      width: 7px;
      height: 7px;
      border-radius: 50%;
      background: rgba(196,168,232,0.2);
      cursor: pointer;
      transition: background 0.2s;
      border: none;
      padding: 0;
    }
    .t-dot.active { background: #C4A8E8; }
  </style>
</head>
<body>
  <canvas id="starfield"></canvas>

  <nav class="site-nav">
    <div class="site-nav__brand">
      <a href="/"><img src="/images/logo/quest-labs-logo.png" alt="Quest Labs — go to homepage" class="site-nav__logo" /></a>
    </div>

    <button class="site-nav__burger" id="navBurger" aria-label="Toggle menu" aria-expanded="false">
      <span></span>
      <span></span>
      <span></span>
    </button>

    <ul class="site-nav__links" id="navLinks">
      {navLinks.map(l => (
        <li class:list={['site-nav__item', { 'has-dropdown': l.dropdown }]}>
          <a
            href={l.href}
            class:list={['site-nav__link', { 'site-nav__link--active': isActive(l.href, l.dropdown) }]}
            aria-current={isActive(l.href, l.dropdown) ? 'page' : undefined}
          >
            {l.label}
            {isActive(l.href, l.dropdown) && <span class="site-nav__dot" aria-hidden="true" />}
          </a>
          {l.dropdown && (
            <ul class="site-nav__dropdown">
              {l.dropdown.map((d: { label: string; href: string }) => (
                <li>
                  <a
                    href={d.href}
                    class:list={['site-nav__dropdown-link', { 'site-nav__link--active': isActive(d.href) }]}
                    aria-current={isActive(d.href) ? 'page' : undefined}
                  >
                    {d.label}
                  </a>
                </li>
              ))}
            </ul>
          )}
        </li>
      ))}
    </ul>
  </nav>

  <slot />

  <script is:inline>
    // Burger menu
    const burger   = document.getElementById('navBurger');
    const navLinks = document.getElementById('navLinks');
    burger.addEventListener('click', () => {
      const open = navLinks.classList.toggle('open');
      burger.classList.toggle('open', open);
      burger.setAttribute('aria-expanded', open);
    });
    navLinks.querySelectorAll('a').forEach(a => {
      a.addEventListener('click', () => {
        navLinks.classList.remove('open');
        burger.classList.remove('open');
        burger.setAttribute('aria-expanded', false);
      });
    });

    // Starfield
    const canvas = document.getElementById('starfield');
    const ctx    = canvas.getContext('2d');
    let stars    = [];
    function resizeCanvas() { canvas.width = window.innerWidth; canvas.height = window.innerHeight; }
    function initStars() {
      stars = [];
      for (let i = 0; i < 200; i++) {
        stars.push({
          x: Math.random() * canvas.width,
          y: Math.random() * canvas.height,
          r: Math.random() * 1.4 + 0.2,
          opacity: Math.random() * 0.6 + 0.1,
          speed: Math.random() * 0.3 + 0.05,
          twinkle: Math.random() * Math.PI * 2,
        });
      }
    }
    function drawStars() {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      stars.forEach(s => {
        s.twinkle += 0.012;
        const o = s.opacity * (0.7 + 0.3 * Math.sin(s.twinkle));
        ctx.beginPath();
        ctx.arc(s.x, s.y, s.r, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(240,220,160,${o})`;
        ctx.fill();
        s.y -= s.speed;
        if (s.y < -5) { s.y = canvas.height + 5; s.x = Math.random() * canvas.width; }
      });
      requestAnimationFrame(drawStars);
    }
    window.addEventListener('resize', () => { resizeCanvas(); initStars(); });
    resizeCanvas(); initStars(); drawStars();
  </script>
</body>
</html>
